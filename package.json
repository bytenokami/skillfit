{
  "name": "skillfit",
  "version": "0.5.0",
  "description": "Composite-skill curator + opt-in installer for Claude Code and Codex CLI. Scans a workspace, drafts a thin per-repo composite skill, optionally installs it.",
  "type": "module",
  "bin": {
    "skillfit": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "node --import tsx src/cli.ts --help"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "author": "skillfit contributors",
  "keywords": [
    "ai",
    "claude",
    "skills",
    "autoskills",
    "agent",
    "tooling"
  ]
}
